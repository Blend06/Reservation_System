# Database Configuration
DB_NAME=reservation_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=postgres
DB_PORT=5432

# Email Configuration (Gmail SMTP)
# YOU (super admin) configure this ONCE for ALL businesses
# Get app password from: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-saas-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
ADMIN_EMAIL=your-saas-email@gmail.com

# WhatsApp Configuration (Twilio)
# YOU (super admin) configure this ONCE for ALL businesses
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# WhatsApp Configuration (Ultramsg - Alternative for testing)
# Only use for testing, not production
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# Notes:
# - Business owners do NOT configure these
# - All emails sent from YOUR Gmail account
# - All WhatsApp messages sent from YOUR Twilio number
